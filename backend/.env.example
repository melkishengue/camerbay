# -------------------------------------------------------
# Copy this to .env (gitignored) for local Docker.
# In Dokploy, set these directly in the Environment Variables UI.
# -------------------------------------------------------

# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://host:5432/camerbay
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# OAuth2 / Zitadel
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Stream.io
STREAM_KEY=
STREAM_SECRET=

# App
DEV_MODE=false

# Traefik
CAMERBAY_DOMAIN=api.yourdomain.com
